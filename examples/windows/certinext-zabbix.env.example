# C:\ProgramData\certinext-zabbix\certinext-zabbix.env
#
# UNTESTED: this file and the rest of examples/windows/ are a starting
# reference, not verified against a real Windows host. Review before
# production use.
#
# KEY=VALUE, one per line, like the systemd/cron examples. Task Scheduler
# has no EnvironmentFile= equivalent, so Invoke-CertinextZabbixPush.ps1
# reads this file and sets each value as a process environment variable
# before calling certinext-zabbix-push.exe.
#
# Restrict this file's ACL to SYSTEM and the service account only, e.g.:
#   icacls "C:\ProgramData\certinext-zabbix\certinext-zabbix.env" `
#     /inheritance:r /grant:r "SYSTEM:(R)" "DOMAIN\svc-certinext-zabbix:(R)"

CERTINEXT_CLIENT_ID=
CERTINEXT_CLIENT_SECRET=
ZABBIX_SERVER=
ZABBIX_HOSTNAME=

# Only if this host lacks direct HTTPS egress to the CertiNext API:
#HTTPS_PROXY=http://proxy.example.org:3128
#NO_PROXY=127.0.0.1,localhost
