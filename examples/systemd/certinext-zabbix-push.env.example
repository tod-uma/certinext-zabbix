# /etc/certinext-zabbix/certinext-zabbix.env
# Mode 0600, owner root:root — systemd's EnvironmentFile= reads this as
# root before dropping to the service's User=.

CERTINEXT_CLIENT_ID=
CERTINEXT_CLIENT_SECRET=
ZABBIX_SERVER=
ZABBIX_HOSTNAME=

# Which domains to monitor: top (default), ns-boundary, or all.
# Uncomment to override the default:
#CERTINEXT_DOMAIN_SCOPE=top

# Only if this host lacks direct HTTPS egress to the CertiNext API:
#HTTPS_PROXY=http://proxy.example.org:3128
#NO_PROXY=127.0.0.1,localhost
